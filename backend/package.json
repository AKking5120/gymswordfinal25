{
  "name": "ecommerce-backend",
  "version": "1.0.0",
  "description": "E-commerce backend with Supabase",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build:frontend": "cd ../frontend && npm install && npm run build && cp -r build ../backend/public",
    "postinstall": "node -e \"if(process.env.NODE_ENV==='production'||process.env.RENDER){require('child_process').execSync('npm run build:frontend',{stdio:'inherit'})}\""
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@supabase/supabase-js": "^2.39.0",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^1.41.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "multer-storage-cloudinary": "^4.0.0",
    "nodemailer": "^9.0.0",
    "pdfkit": "^0.19.1",
    "pg": "^8.21.0",
    "razorpay": "^2.9.6",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
